<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>View Record - <%= record.patientName %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <style>
    body {
      background: #f7faff;
      font-family: 'Poppins', sans-serif;
    }
    .header {
      background: #fff;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
      padding: 15px 30px;
      margin-bottom: 30px;
    }
    .header h3 {
      color: #007bff;
      font-weight: 600;
    }
    .record-container {
      max-width: 700px;
      margin: 0 auto;
    }
    .record-card {
      background: #fff;
      border-radius: 15px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
      padding: 25px;
      margin-bottom: 25px;
    }
    .record-field {
      margin-bottom: 12px;
    }
    .record-field strong {
      color: #007bff;
      display: inline-block;
      width: 140px;
    }
    .view-btn {
      background: #007bff;
      color: #fff;
      border-radius: 10px;
      padding: 10px 20px;
      text-decoration: none;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .view-btn:hover {
      background: #0056b3;
    }
    .back-btn {
      display: inline-block;
      margin-top: 10px;
      background: #0d6efd;
      color: #fff;
      padding: 10px 18px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 500;
    }
    footer {
      text-align: center;
      margin-top: 40px;
      font-size: 14px;
      color: #777;
    }
  </style>
</head>
<body>

  <!-- Header Section -->
  <div class="header text-center">
    <h3>🩺 My Medical Record</h3>
  </div>

  <!-- Record Card Section -->
  <div class="record-container">
    <div class="record-card">
      <div class="record-field"><strong>Patient Name:</strong> <%= record.patientName %></div>
      <div class="record-field"><strong>Doctor:</strong> <%= record.doctor %></div>
      <div class="record-field"><strong>Diagnosis:</strong> <%= record.diagnosis %></div>
      <div class="record-field"><strong>Treatment:</strong> <%= record.treatment %></div>

      <% if(record.file && record.file.url){ %>
        <div class="record-field">
          <strong>Uploaded File:</strong> 
          <a class="view-btn" href="<%= record.file.url %>" target="_blank">
            📄 View File
          </a>
        </div>
      <% } %>

      <div class="record-field">
        <strong>Date:</strong> <%= record.createdAt && record.createdAt.toDate ? record.createdAt.toDate().toLocaleString() : (record.createdAt ? new Date(record.createdAt).toLocaleString() : 'N/A') %>
      </div>

      <a href="/dashboard" class="back-btn">⬅ Back to Dashboard</a>
    </div>
  </div>


</body>
</html>
